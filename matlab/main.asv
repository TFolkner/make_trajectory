clear;
clc;


%% Начальная и конечная точка на сфере Земли в ГСК
m0 = [55.7500, 37.6167]; % МСК
m1 = [59.9500, 30.3167];% СПБ

m0 = rad2deg(m0);
m1 = rad2deg(m1);

t = 10; % Время в движении [sec]

W_earth = 7.2921159e-5; % [1/sec]
M_IE = [cos(W_earth * t), -sin(W_earth * t), 0;
        sin(W_earth * t), cos(W_earth * t), 0;
        0, 0, 1];

%% main cycle

% Орты нормалей в ГСК
e0 = [cos(m0(1)) * cos(m0(2));
      cos(m0(1)) * sin(m0(2));
      sin(m0(1))];


e1 = [cos(m1(1)) * cos(m1(2));
      cos(m1(1)) * sin(m1(2));
      sin(m1(1))];


% Орты нормалей в ИСК
e0_ = M_IE * e0;
e1_ = M_IE * e1;


 